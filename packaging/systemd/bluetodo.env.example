# BlueTodo systemd environment
#
# Copy to /etc/bluetodo/bluetodo.env and adjust as needed.

BLUETODO_DB_PATH=/var/lib/bluetodo/bluetodo.db
BLUETODO_MASTER_KEY_FILE=/etc/bluetodo/master.key

# Optional: override the writable app config path used by the web UI
# BLUETODO_CONFIG=/var/lib/bluetodo/config.env

# Optional: client update artifacts from separate client repositories
# BLUETODO_WIN16_UPDATE_EXE=/srv/bluetodo-updates/win16/BLUETODO.EXE
# BLUETODO_WIN16_UPDATER_EXE=/srv/bluetodo-updates/win16/BTUPDT16.EXE
# BLUETODO_NT4PPC_UPDATE_EXE=/srv/bluetodo-updates/nt4ppc/bluetodo-nt4ppc.exe
# BLUETODO_NT4PPC_UPDATER_EXE=/srv/bluetodo-updates/nt4ppc/btupdt32-nt4ppc.exe
